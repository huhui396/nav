# Turso Edge Database
# 1. Create a free database at https://turso.tech
# 2. Run: turso db show <your-db-name> --url
# 3. Run: turso db tokens create <your-db-name>
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Optional: Add Clerk keys here when you're ready to wire up auth
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
