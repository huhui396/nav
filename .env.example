# Netlify DB (Neon Postgres) — 在 Netlify 控制台开启后自动注入，本地开发时手动填写
# 获取方式：Netlify 控制台 → 你的 Site → Storage → Database → Connect
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# Optional: Add Clerk keys here when you're ready to wire up auth
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
